# ── Supabase ────────────────────────────────────────────────────────
# Public — safe to expose to the browser / client.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only — used by seed/backfill scripts and trusted server code.
# Bypasses RLS. NEVER ship to any client (data-model skill §4).
SUPABASE_SERVICE_ROLE_KEY=

# ── Instagram (v1 ONLY — see ig-sync skill. Leave empty in v0.) ──────
IG_APP_ID=
IG_APP_SECRET=
IG_WEBHOOK_VERIFY_TOKEN=
IG_TOKEN_ENCRYPTION_KEY=
