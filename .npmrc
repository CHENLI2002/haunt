# React Native / Metro do not support pnpm's default isolated node_modules layout
# (phantom-dependency resolution failures, e.g. @babel/runtime). Install hoisted/flat
# so Metro and Babel resolve transitive deps the way the RN ecosystem expects.
# Web (Next.js) is unaffected. The @types/react override in package.json keeps types single-versioned.
node-linker=hoisted
